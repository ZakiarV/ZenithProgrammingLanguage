export _start


TEXT

function linux_syscall : special SYSCALL
    locals :
        str_r10 8 : reg : r10
        str_r11 8 : reg : r11
    endlocals

    mov r10, rcx
    syscall

    mov rcx, r10
    mov r10, QWORD [str_r10]
    mov r11, QWORD [str_r11]

    return 1 : rax
end


function syscall_wrapper :
    locals :
        str_rdi 8 : reg : rdi
        str_rsi 8 : reg : rsi
        str_rdx 8 : reg : rdx
        str_rcx 8 : reg : rcx
        str_r8 8 : reg : r8
        str_r9 8 : reg : r9
        result 8 : stack
    endlocals

    call linux_syscall : narg 7 : special SYSCALL_ARGS : args [ rdi, rsi, rdx, rcx, [r9], [r9+8], [8*r8+r9] ]

    test rax, rax
    js .failed
    mov rdi, QWORD [str_rdi]
    mov rsi, QWORD [str_rsi]
    mov rdx, QWORD [str_rdx]
    mov rcx, QWORD [str_rcx]
    return 1 : rax
.failed :
    and rax, 0xFF
    mov rdi, rax
    mov rax, 60
    syscall
end



function _start :
    locals :
        argc 8 : stack
        argv 8 : stack
    endlocals

    mov rdi, [rsp+16]
    lea rsi, [rsp+24]

    mov QWORD [argc], rdi
    mov QWORD [argv], rsi

    call main : std : 2, [ [argc], [argv] ]

end

ENDTEXT


DATA

ENDDATA